# Session manager configuration.
# Copy this to config.yml and fill in secrets before running.

listen: "127.0.0.1:8080"
web_dir: "/app/web"
saves_root: "/srv/df/users"

image_sdl:  "df-image-sdl"
docker_network: "df_internal"

idle_timeout: "30m"
max_sessions: 5

# Generate with: openssl rand -hex 32
cookie_key: "REPLACE_WITH_64_HEX_CHARS"

# WebAuthn relying party settings — must match the origin users visit.
rp_id: "example.com"
rp_display_name: "Dwarf Fortress"
rp_origins:
  - "https://example.com"

# OIDC (Nextcloud) — leave blank to disable.
oidc_issuer: ""          # e.g. https://cloud.example.com
oidc_client_id: ""
oidc_client_secret: ""
oidc_redirect_uri: ""    # e.g. https://df.example.com/auth/oidc/callback

# DFHack integration — set to true only when df-image-sdl was built with
# --build-arg DFHACK_VERSION=<version>. Exposes the in-browser labor panel
# and surfaces the in-game manipulator hint. Leave false for vanilla DF.
dfhack_enabled: false
