#!/bin/sh
# Wait for Xvfb socket and VNC port before launching DF.
until [ -S /tmp/.X11-unix/X0 ]; do sleep 0.2; done
until nc -z 127.0.0.1 5900 2>/dev/null; do sleep 0.3; done
until [ -S /tmp/pulse/native ]; do sleep 0.2; done

export DISPLAY=:0
export PULSE_SERVER=unix:/tmp/pulse/native
export SDL_AUDIODRIVER=pulse
cd /opt/df

# Apply user-uploaded tilesets and selection. Non-fatal on error.
/apply-tilesets.sh || true

# On SIGTERM (sent by s6 during container shutdown) send the in-game quit-save
# key sequence, then wait for DF to finish writing the save before exiting.
# s6 sends SIGTERM only to this shell's PID, not to the DF process group, so DF
# stays alive long enough for the key sequence to take effect.
_quit() {
    /quit-sdl.sh
    wait "$DF_PID" 2>/dev/null
    exit 0
}
trap _quit TERM

./dwarfort &
DF_PID=$!

# Without a window manager, DF's SDL2 window never receives X11 input focus,
# so all keyboard and mouse button events from the VNC server are lost.
# Wait for the window to appear and give it focus explicitly.
xdotool search --sync --name "Dwarf Fortress" windowfocus &

wait "$DF_PID"
